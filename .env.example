VITE_GATEWAY_URL=http://127.0.0.1:18789 # OpenClaw 系统 API 地址
VITE_WS_URL=ws://127.0.0.1:18789 # OpenClaw 系统 WebSocket 地址
VITE_GATEWAY_TOKEN=your_gateway_token_here # OpenClaw 系统 API Token
# ─────────────────── 计费模式（费用统计）───────────────────
# VITE_COST_MODE 可选值：
#   electricity   - 本地模型部署用：费用 = API 实际费用 + 电费（uptime × 元/小时）
#   subscription  - 订阅 API 用：费用 = API 实际费用 + 月订阅费按运行时长比例分摊
#   api_only      - 纯 API 计费：费用 = API 实际费用（不附加任何成本）
# 默认 electricity（兼容原作者本地模型逻辑）
VITE_COST_MODE=electricity

# 电费单价（元/小时）—— 仅 VITE_COST_MODE=electricity 时生效
VITE_ELECTRICITY_PER_HOUR=2

# 月订阅总费用（元/月）—— 仅 VITE_COST_MODE=subscription 时生效
# 示例：ChatGPT Plus 约 ¥140 + Claude Pro 约 ¥140 = ¥280
VITE_SUBSCRIPTION_MONTHLY_CNY=280
VITE_BACKEND_URL=http://127.0.0.1:31002 # 统一服务 API 地址（合并了 GPU VRAM + Usage Stats + Reset Agent）
# Agent 中文称呼配置（与 openclaw.json agents.list[].name 保持一致）
# 格式：VITE_AGENT_<id>=<中文名称>（id 中连字符用下划线替换）
# API 失败时作为降级方案
# VITE_AGENT_main=副总
# VITE_AGENT_recorder=执行秘书
# VITE_AGENT_backend=后端
# VITE_AGENT_frontend=前端
# VITE_AGENT_debugger=调试员
# VITE_AGENT_codeaudit=代码审计
# VITE_AGENT_testing=测试
# VITE_AGENT_devops=运维
# VITE_AGENT_architect=架构师
# VITE_AGENT_product=产品经理
# VITE_AGENT_requirements=需求分析
# VITE_AGENT_researchassistant=调研员
# VITE_AGENT_seo=网站运营
# VITE_AGENT_uiux=设计师
# VITE_AGENT_comfyui=Comfy
# VITE_AGENT_lesson_assistant=教研员
# VITE_AGENT_ppt_master=PPT制作
# VITE_AGENT_supervisor=监督员
